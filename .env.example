# Copy this file to .env and fill in real values.
# Never commit .env — it is listed in .gitignore.

# OpenAI
OPENAI_API_KEY=replace-with-openai-api-key
MODEL_NAME=gpt-4o

# PGVector (vector database collection)
COLLECTION_NAME=replace-with-pgvector-collection-name

# PostgreSQL
DB_USER=replace-with-db-user
DB_PASS=replace-with-db-password
DB_HOST=replace-with-db-host
DB_PORT=5432
DB_NAME=replace-with-db-name
